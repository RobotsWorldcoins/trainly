{
  "name": "trainly",
  "version": "1.0.0",
  "private": true,
  "description": "Trainly — Outdoor fitness discovery and booking platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "pnpm --filter @trainly/mobile start",
    "mobile:android": "pnpm --filter @trainly/mobile android",
    "mobile:ios": "pnpm --filter @trainly/mobile ios",
    "admin": "pnpm --filter @trainly/admin dev",
    "admin:build": "pnpm --filter @trainly/admin build",
    "db:migrate": "supabase db push",
    "db:seed": "supabase db seed",
    "db:reset": "supabase db reset",
    "db:types": "supabase gen types typescript --local > packages/shared/src/types/supabase.ts",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "validate:env": "node scripts/validate-env.js all",
    "validate:mobile": "node scripts/validate-env.js mobile",
    "validate:admin": "node scripts/validate-env.js admin"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
