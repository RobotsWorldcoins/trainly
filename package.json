{
  "name": "trainyx",
  "version": "1.0.0",
  "private": true,
  "description": "TrainyX — Outdoor fitness discovery and booking platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "pnpm --filter @trainyx/mobile start",
    "mobile:android": "pnpm --filter @trainyx/mobile android",
    "mobile:ios": "pnpm --filter @trainyx/mobile ios",
    "admin": "pnpm --filter @trainyx/admin dev",
    "admin:build": "pnpm --filter @trainyx/admin build",
    "db:migrate": "supabase db push",
    "db:seed": "supabase db seed",
    "db:reset": "supabase db reset",
    "db:types": "supabase gen types typescript --local > packages/shared/src/types/supabase.ts",
    "validate:env": "node scripts/validate-env.js all"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.1.0"
}
