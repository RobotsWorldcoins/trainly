{
  "expo": {
    "name": "Trainly",
    "slug": "trainly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "trainly",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B2A4A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.trainly.mobile",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "A Trainly usa a tua localização para mostrar sessões perto de ti e para validar a tua presença.",
        "NSCameraUsageDescription": "A câmara é usada para fazer upload de documentos e foto de perfil.",
        "NSPhotoLibraryUsageDescription": "A galeria é usada para selecionar a tua foto de perfil ou documentos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1B2A4A"
      },
      "package": "app.trainly.mobile",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "A Trainly usa a tua localização para mostrar sessões perto de ti.",
          "locationWhenInUsePermission": "A Trainly usa a tua localização para mostrar sessões perto de ti."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "A câmara é usada para documentos e foto de perfil."
        }
      ],
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsDownloadToken": "MAPBOX_DOWNLOAD_TOKEN_PLACEHOLDER"
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.app.trainly"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
