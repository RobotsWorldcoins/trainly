# ─────────────────────────────────────────────
# TrainyX — Environment Variables Template
# Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# ── Environment ──────────────────────────────
NODE_ENV=development
# Set to "true" to enable dev testing overlay and seeded accounts
EXPO_PUBLIC_DEV_MODE=true

# ── Supabase ─────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe ───────────────────────────────────
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-secret
# Platform account ID (receives commissions)
STRIPE_PLATFORM_ACCOUNT_ID=acct_your-platform-id

# ── Mapbox ───────────────────────────────────
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.eyJ1Ijoidm91ci11c2VybmFtZSIsImEiOiJ5b3VyLXRva2VuIn0.your-token

# ── App Config ───────────────────────────────
EXPO_PUBLIC_APP_NAME=TrainyX
EXPO_PUBLIC_APP_SCHEME=trainyx
EXPO_PUBLIC_DEFAULT_CITY=Lisbon
EXPO_PUBLIC_DEFAULT_LAT=38.7223
EXPO_PUBLIC_DEFAULT_LNG=-9.1393
EXPO_PUBLIC_DEFAULT_RADIUS_KM=10

# ── Platform Fees ────────────────────────────
PLATFORM_COMMISSION_DEFAULT=0.10
PLATFORM_COMMISSION_EARLY_TRAINER=0.05
PLATFORM_COMMISSION_EARLY_DAYS=90

# ── Admin Dashboard (Next.js) ─────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# ── Stripe Price IDs (created in Stripe dashboard) ───
# User Plus — €4.99 one-time
STRIPE_PRICE_USER_PLUS=price_1TOdgu7RLKcygRElDZSptVbg
# Trainer plan — €19/month
STRIPE_PRICE_TRAINER=price_1TOdh17RLKcygREl8UPEbeSp
# Coach Pro — €39/month
STRIPE_PRICE_COACH_PRO=price_1TOdh47RLKcygREl5A1M29o6
# Platform Stripe account ID
STRIPE_PLATFORM_ACCOUNT_ID=acct_1SLn6X7RLKcygREl

# ── App scheme (for deep links) ──────────────────────
APP_SCHEME=trainyx
